# Environment Configuration
ENVIRONMENT=production
DEBUG=false

# Local debug crops
# Set ENVIRONMENT=local or SAVE_DEBUG_CROPS=true to save debug images.
SAVE_DEBUG_CROPS=false
DEBUG_CROPS_DIR=./debug_crops

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes
REQUEST_TIMEOUT=300     # 5 minutes

# CORS Configuration
CORS_ORIGINS=https://neurocraft-frontend.onrender.com,https://yourdomain.com

# Logging
LOG_LEVEL=info
