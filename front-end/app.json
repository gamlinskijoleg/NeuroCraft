{
    "expo": {
        "name": "Road Vision",
        "slug": "front-end",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "front-end",
        "userInterfaceStyle": "dark",
        "splash": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#07111D"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.anonymous.frontend",
            "runtimeVersion": {
                "policy": "appVersion"
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/android-icon-foreground.png",
                "backgroundImage": "./assets/images/android-icon-background.png",
                "monochromeImage": "./assets/images/android-icon-monochrome.png"
            },
            "package": "com.anonymous.frontend",
            "permissions": ["android.permission.RECORD_AUDIO"],
            "runtimeVersion": "1.0.0"
        },
        "plugins": [
            "expo-router",
            [
                "expo-image-picker",
                {
                    "photosPermission": "The app accesses your photos to scan road images."
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "API_URL": "https://gamlinskijoleg-easyroad.hf.space/",
            "router": {},
            "eas": {
                "projectId": "8bed685c-c142-47ce-8a45-b9e3518c797d"
            }
        },
        "updates": {
            "url": "https://u.expo.dev/8bed685c-c142-47ce-8a45-b9e3518c797d"
        },
        "owner": "neurocraft-team"
    }
}
