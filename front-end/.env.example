# API Configuration
# Copy this file to your environment when needed

# Development (iOS Simulator)
# EXPO_PUBLIC_API_URL=http://localhost:8000

# Development (Android Emulator)
# No need to set - defaults to http://10.0.2.2:8000

# Development (Physical Device - Windows)
# EXPO_PUBLIC_API_URL=http://192.168.1.50:8000

# Production (Render or other hosting)
# EXPO_PUBLIC_API_URL=https://your-api-url.render.com
